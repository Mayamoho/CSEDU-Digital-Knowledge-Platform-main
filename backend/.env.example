# ============================================================
# CSEDU Digital Knowledge Platform — Backend Environment
# ============================================================

# ============================================================
# DATABASE (PostgreSQL with pgvector)
# ============================================================
DB_USER=csedu_user
DB_PASSWORD=changeme_in_production
DB_NAME=csedu_platform
DB_HOST=postgres
DB_PORT=5432

# ============================================================
# REDIS (Caching & Queue)
# ============================================================
REDIS_URL=redis://redis:6379

# ============================================================
# MINIO (S3-Compatible Object Storage)
# ============================================================
MINIO_USER=minioadmin
MINIO_PASSWORD=changeme_in_production
MINIO_BUCKET=csedu-files
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false

# ============================================================
# JWT AUTHENTICATION
# ============================================================
# IMPORTANT: Change JWT_SECRET in production (minimum 32 characters)
JWT_SECRET=change_this_to_a_secure_random_string_min_32_chars
JWT_EXPIRY_HOURS=1
REFRESH_EXPIRY_DAYS=7

# ============================================================
# FINE CALCULATION (Library Fines in BDT)
# ============================================================
FINE_RATE_PER_DAY=50
FINE_RATE_BDT_PER_DAY=50.0
MAX_FINE_PER_LOAN_BDT=500.0
FINE_CALC_INTERVAL=24h
FINE_BLOCK_THRESHOLD=500
FINE_BLOCK_THRESHOLD_BDT=500.0
LOAN_PERIOD_DAYS=14

# ============================================================
# GROQ API (Primary LLM - Free Tier Available)
# ============================================================
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_SIMPLE=llama-3.1-8b-instant
GROQ_MODEL_LONG=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_COMPLEX=openai/gpt-oss-120b
GROQ_TIMEOUT=30

# ============================================================
# GEMINI API (Fallback LLM + Query Rewriting)
# ============================================================
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# ============================================================
# RAG SERVICE CONFIGURATION
# ============================================================
RAG_SERVICE_URL=http://rag:8001

# Embedding Model Configuration
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=768

# Text Chunking Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval Configuration
TOP_K_RESULTS=10
VECTOR_SEARCH_LIMIT=8
FTS_SEARCH_LIMIT=8

# Query Configuration
MAX_QUERY_LENGTH=5000
MIN_QUERY_LENGTH=3
MAX_CONTEXT_WINDOW=10

# ============================================================
# APPLICATION SETTINGS
# ============================================================
APP_ENV=production
PORT=8080

# ============================================================
# MONITORING (Optional - Grafana)
# ============================================================
GF_SECURITY_ADMIN_PASSWORD=admin
