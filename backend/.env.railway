# ============================================================
# Railway Environment Variables Template
# Copy these to Railway dashboard for each service
# ============================================================

# ============================================================
# API SERVICE ENVIRONMENT VARIABLES
# ============================================================

# Database (Railway auto-fills these)
DATABASE_URL=${{Postgres.DATABASE_URL}}
DB_HOST=${{Postgres.PGHOST}}
DB_PORT=${{Postgres.PGPORT}}
DB_USER=${{Postgres.PGUSER}}
DB_PASSWORD=${{Postgres.PGPASSWORD}}
DB_NAME=${{Postgres.PGDATABASE}}

# Redis (Railway auto-fills)
REDIS_URL=${{Redis.REDIS_URL}}

# MinIO / S3 Storage
# Option 1: Cloudflare R2 (Recommended - Free 10GB)
# Get credentials from: https://dash.cloudflare.com/
MINIO_ENDPOINT=<account-id>.r2.cloudflarestorage.com
MINIO_USER=<your-r2-access-key-id>
MINIO_PASSWORD=<your-r2-secret-access-key>
MINIO_BUCKET=csedu-files
MINIO_USE_SSL=true

# Option 2: AWS S3
# MINIO_ENDPOINT=s3.amazonaws.com
# MINIO_USER=<your-aws-access-key>
# MINIO_PASSWORD=<your-aws-secret-key>
# MINIO_BUCKET=csedu-files
# MINIO_USE_SSL=true

# JWT Authentication
# IMPORTANT: Generate a strong random string (32+ characters)
# Use: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRY_HOURS=1
REFRESH_EXPIRY_DAYS=7

# Fine Configuration
FINE_RATE_PER_DAY=50
FINE_RATE_BDT_PER_DAY=50.0
MAX_FINE_PER_LOAN_BDT=500.0
FINE_CALC_INTERVAL=24h
FINE_BLOCK_THRESHOLD=500
FINE_BLOCK_THRESHOLD_BDT=500.0
LOAN_PERIOD_DAYS=14

# Groq API (Primary LLM)
# Get free API key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL_SIMPLE=llama-3.1-8b-instant
GROQ_MODEL_LONG=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_COMPLEX=openai/gpt-oss-120b
GROQ_TIMEOUT=30

# Gemini API (Fallback LLM - Optional)
# Get API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# RAG Service URL
# After deploying RAG service, update this with its Railway URL
RAG_SERVICE_URL=https://your-rag-service.up.railway.app

# CORS Configuration
# Add your Vercel frontend URL
ALLOWED_ORIGINS=https://your-project.vercel.app,https://yourdomain.com

# Application Settings
APP_ENV=production
PORT=8080

# ============================================================
# RAG SERVICE ENVIRONMENT VARIABLES
# ============================================================

# Database (Reference from PostgreSQL service)
DB_HOST=${{Postgres.PGHOST}}
DB_PORT=${{Postgres.PGPORT}}
DB_USER=${{Postgres.PGUSER}}
DB_PASSWORD=${{Postgres.PGPASSWORD}}
DB_NAME=${{Postgres.PGDATABASE}}

# Redis
REDIS_URL=${{Redis.REDIS_URL}}

# Groq API
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL_SIMPLE=llama-3.1-8b-instant
GROQ_MODEL_LONG=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_COMPLEX=openai/gpt-oss-120b
GROQ_TIMEOUT=30

# Gemini API (Optional)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# Embedding Model Configuration
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=768

# Text Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval Configuration
TOP_K_RESULTS=10
VECTOR_SEARCH_LIMIT=8
FTS_SEARCH_LIMIT=8

# Query Configuration
MAX_QUERY_LENGTH=5000
MIN_QUERY_LENGTH=3
MAX_CONTEXT_WINDOW=10

# ============================================================
# NOTES FOR RAILWAY DEPLOYMENT
# ============================================================

# 1. Railway Reference Variables:
#    Use ${{ServiceName.VARIABLE}} to reference other services
#    Example: ${{Postgres.DATABASE_URL}}

# 2. Required Services in Railway:
#    - PostgreSQL (Add via Railway dashboard)
#    - Redis (Add via Railway dashboard)
#    - API Service (Deploy from backend/api)
#    - RAG Service (Deploy from backend/rag)

# 3. Storage Options:
#    - Cloudflare R2: Free 10GB, S3-compatible
#    - AWS S3: Pay as you go
#    - Railway Volume: Limited, not recommended

# 4. After Deployment:
#    - Initialize database with init.sql
#    - Update RAG_SERVICE_URL in API service
#    - Update ALLOWED_ORIGINS with Vercel URL
#    - Change default passwords in database

# 5. Security:
#    - Generate strong JWT_SECRET
#    - Use environment-specific secrets
#    - Enable HTTPS (Railway provides automatically)
#    - Rotate API keys regularly
