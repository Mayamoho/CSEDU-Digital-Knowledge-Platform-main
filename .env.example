# ============================================================
# CSEDU Digital Knowledge Platform — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# Database (PostgreSQL)
DB_USER=csedu_user
DB_PASSWORD=changeme_in_prod
DB_NAME=csedu_platform
DB_HOST=postgres
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379

# MinIO (S3-compatible storage)
MINIO_USER=minioadmin
MINIO_PASSWORD=changeme_in_prod
MINIO_BUCKET=csedu-files
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false

# JWT
JWT_SECRET=super_secret_jwt_key_change_this_in_prod_min_32_chars
JWT_EXPIRY_HOURS=1
REFRESH_EXPIRY_DAYS=7

# Fine calculation (BDT)
FINE_RATE_BDT_PER_DAY=50.0
MAX_FINE_PER_LOAN_BDT=500.0
FINE_CALC_INTERVAL=24h
FINE_BLOCK_THRESHOLD_BDT=50.0
LOAN_PERIOD_DAYS=14

# Groq (primary LLM — free tier, no credit card needed)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL_SIMPLE=llama-3.1-8b-instant
GROQ_MODEL_LONG=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_COMPLEX=openai/gpt-oss-120b
GROQ_TIMEOUT=30

# Gemini (fallback LLM + query rewriting)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash-exp

# RAG Service Configuration
RAG_SERVICE_URL=http://rag:8001
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=768
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=10
VECTOR_SEARCH_LIMIT=8
FTS_SEARCH_LIMIT=8

# Query Configuration
MAX_QUERY_LENGTH=5000
MIN_QUERY_LENGTH=3
MAX_CONTEXT_WINDOW=10

# SSO Configuration (Optional)
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=http://localhost/api/v1/auth/sso/callback
SSO_PROVIDER_URL=

# Next.js public vars (exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# App
APP_ENV=development
PORT=8080

